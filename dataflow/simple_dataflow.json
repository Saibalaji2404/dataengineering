{
	"name": "simple_dataflow",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "dataflowread",
						"type": "DatasetReference"
					},
					"name": "readdata"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "dataflowtarget",
						"type": "DatasetReference"
					},
					"name": "targetdata"
				}
			],
			"transformations": [],
			"scriptLines": [
				"source(output(",
				"          Emp_No as string,",
				"          Emp_Name as string,",
				"          Emp_Salary as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> readdata",
				"readdata sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> targetdata"
			]
		}
	}
}